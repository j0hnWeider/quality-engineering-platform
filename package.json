{
  "name": "quality-engineering-platform",
  "version": "1.0.0",
  "description": "Framework de automação de testes com arquitetura híbrida",
  "scripts": {
    "test:api": "npx playwright test --project=api",
    "test:ui": "npx playwright test --project=ui",
    "test:all": "npx playwright test",
    "test:perf": "k6 run src/performance/stress-test.js",
    "test:zap": "bash src/security/zap-baseline-scan.sh",
    "test:security": "npx playwright test --project=api --grep security",
    "pretest": "npx playwright install",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "coverage": "nyc npm run test:all",
    "mutation": "stryker run"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@playwright/test": "^1.42.0",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "allure-playwright": "^2.12.0",
    "dotenv": "^16.4.0",
    "eslint": "^8.57.0",
    "nyc": "^15.1.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0"
  }
}
